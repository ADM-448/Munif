import pandas as pd
from sklearn.pipeline import Pipeline
from sklearn.preprocessing import StandardScaler, LabelEncoder
from sklearn.neighbors import KNeighborsClassifier
from sklearn.metrics import classification_report, confusion_matrix, accuracy_score
from sklearn.model_selection import train_test_split 

# 1. LEITURA DOS DADOS [cite: 238, 239, 251]
SHEET_ID = "1Zu3r88U8q9xanSy8VDB2QN26J3wkhqCXUua43zj4Wyw"
GID = "0"
url_tsv = f"https://docs.google.com/spreadsheets/d/{SHEET_ID}/export?format=tsv&gid={GID}"

df = pd.read_csv(url_tsv, sep="\t", decimal=",")

# Padronização de colunas para evitar erros de digitação
df.columns = df.columns.str.strip().str.lower()
print("Colunas detectadas:", list(df.columns))

# 2. ESCOLHA DAS FEATURES E CLASSE (Ajustado para seus dados reais) 
# Aqui definimos grupos de colunas para você testar no relatório 
FEATURE_SETS = {
    "A": ["anos_exp", "projetos"],
    "B": ["nota_php", "ingles"],
    "C": ["anos_exp", "nota_php", "ingles"],
    "TUDO": ["anos_exp", "projetos", "nota_php", "ingles"]
}

# --- ALTERE AQUI PARA SEUS TESTES ---
FEATURES = FEATURE_SETS["A"] 
TARGET = "resultado" 
K_VIZINHOS = 3 
# ------------------------------------

# Limpeza e conversão [cite: 272, 273, 275, 277]
for col in FEATURES:
    df[col] = pd.to_numeric(df[col], errors="coerce")

df[TARGET] = df[TARGET].astype(str).str.strip().str.lower()
df = df.dropna(subset=FEATURES + [TARGET]).copy()

# 3. CODIFICAÇÃO E DIVISÃO (20% TESTE) [cite: 281, 282, 291]
if not df.empty:
    le = LabelEncoder()
    X = df[FEATURES].values
    y = le.fit_transform(df[TARGET])

    # Separação de 20% para teste conforme solicitado [cite: 292]
    X_train, X_test, y_train, y_test = train_test_split(
        X, y, test_size=0.20, random_state=42
    )

    # 4. TREINAMENTO (KNN) [cite: 310, 314, 316, 321]
    # O StandardScaler normaliza as escalas (ex: anos de 0-10 vs nota 0-100) [cite: 317, 360]
    model = Pipeline(steps=[
        ("scaler", StandardScaler()),
        ("knn", KNeighborsClassifier(n_neighbors=K_VIZINHOS, weights="distance"))
    ])

    model.fit(X_train, y_train)

    # 5. AVALIAÇÃO E MATRIZ DE CONFUSÃO [cite: 322, 325, 330]
    y_pred = model.predict(X_test)

    print(f"\n--- RESULTADOS (K={K_VIZINHOS}, Features={FEATURES}) ---")
    print(f"Acurácia: {accuracy_score(y_test, y_pred):.2f}")
    print("\nMatriz de Confusão (Real x Previsto):")
    print(confusion_matrix(y_test, y_pred))
    print("\nRelatório:")
    print(classification_report(y_test, y_pred, target_names=le.classes_))
    print(df[TARGET].value_counts())
else:
    print("DataFrame vazio após limpeza. Verifique se os nomes das colunas no Sheets estão corretos.")